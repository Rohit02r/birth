# Create .gitignore to exclude node_modules and build files
cat > .gitignore << 'EOF'
# Dependencies
node_modules/
package-lock.json

# Build files
build/
dist/

# Environment variables
.env
.env.local
.env.production

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
EOF